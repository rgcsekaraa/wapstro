# Copy to /etc/wapstro.env on the Oracle VM and fill in the real values.

# Target group for daily posts. Required if BOT_DAILY_ENABLED=true.
GROUP_JID=120363xxxxxxxxxxxx@g.us

# Set false if GitHub Actions daily.yml should keep doing the daily group post.
BOT_DAILY_ENABLED=false

# Set true if /date and /range should work inside WhatsApp groups.
ALLOW_GROUP_COMMANDS=true

# Set true if commands should work in WhatsApp's "message yourself" chat.
ALLOW_SELF_COMMANDS=false

# Optional: comma-separated phone numbers allowed to use /date and /range.
# Leave empty to allow all personal chats.
ALLOWED_SENDERS=

# Optional: expose a local health endpoint.
# Use 127.0.0.1:8765 unless you intentionally want public health checks.
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8765

# Optional bootstrap/session persistence.
# If you run `npm run link` directly on the VM, WA_CREDS can stay empty.
WA_CREDS=
WA_ENC_KEY=
